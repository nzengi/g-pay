# Copy to deploy/.env and fill in. NEVER commit the real .env.

# Postgres / Redis credentials. Generate with `openssl rand -hex 24`.
PG_PASSWORD=replace-me-with-strong-random
REDIS_PASSWORD=replace-me-with-strong-random

# Shared secret between indexer and api-gateway for /v1/internal/*
# `openssl rand -hex 32`
INTERNAL_SECRET=replace-me-with-strong-random

# Solana RPC endpoint and the deployed Anchor program id.
GPAY_RPC_URL=https://api.devnet.solana.com
PROGRAM_ID=75HuPfb2n7SD7KtcQnVpCW5SVN3RP9gZ9vTXP4D4ha6C

# Optional tuning.
SCAN_INTERVAL_MS=5000
RUST_LOG=info
